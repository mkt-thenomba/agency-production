# Copia este archivo a .env (para desarrollo local) o configúralo en Vercel
# Settings → Environment Variables (para producción)

# === IMPRESCINDIBLES ===
ANTHROPIC_API_KEY=sk-ant-tu-clave-aqui

# === BASE DE DATOS ===
# Local: deja vacío y usa SQLite (./data/agency.db)
# Vercel: pega aquí el connection string de Neon (postgresql://...)
DATABASE_URL=

# === OPCIONAL ===
# Modelo Claude (claude-sonnet-4-6 por defecto, claude-opus-4-6 para máxima calidad)
CLAUDE_MODEL=claude-sonnet-4-6

# Protección con password compartido (opcional).
# Si lo dejas vacío, la app es pública sin login.
# Para activarlo: pon una contraseña aquí y todos los visitantes la pedirán una vez.
SITE_PASSWORD=

# Secret para firmar cookies (cualquier string aleatorio largo)
SESSION_SECRET=cambia-esto-por-algo-aleatorio-largo

# Puerto en local (Vercel lo ignora)
PORT=8765
